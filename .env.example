# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
# → Generate new private key. Set as a single-line JSON string or a file path.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Alternatively, provide a file path:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

FIREBASE_PROJECT_ID=snapinfo-53272

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8081,https://snapinfo.app

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Max requests per RATE_LIMIT_WINDOW_MS per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ─── Expo Push ───────────────────────────────────────────────────────────────
# Expo access token from expo.dev — required for production sends
# Get it from: https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# ─── Campaign delivery ────────────────────────────────────────────────────────
# How often the scheduler polls Firestore for due campaigns (milliseconds)
SCHEDULER_POLL_INTERVAL_MS=60000

# Max concurrent Expo chunk sends (each chunk = 100 messages)
SEND_CONCURRENCY=3

# Max retries for transient failures per chunk
MAX_CHUNK_RETRIES=3

# Delay between retries in milliseconds (exponential backoff applied)
RETRY_BASE_DELAY_MS=2000
